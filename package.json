{
  "name": "logseq-vimeditor-plugin",
  "author": "benjypng",
  "description": "Adds a Vim editor to your Logseq graph.",
  "license": "MIT",
  "logseq": {
    "id": "logseq-vimeditor-plugin",
    "title": "logseq-vimeditor-plugin",
    "icon": "./icon.svg",
    "main": "dist/index.html"
  },
  "scripts": {
    "dev": "bunx vite",
    "build": "bunx vite build",
    "prepare": "husky",
    "lint:precommit": "echo \"Running biome\" && bunx biome check . --write && echo \"Running tsc\" && tsc --noEmit"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/github",
        {
          "assets": [
            "logseq-vimeditor-plugin.zip"
          ]
        }
      ]
    ]
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@logseq/libs": "^0.0.17",
    "@replit/codemirror-vim": "^6.3.0",
    "@susisu/mte-kernel": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/node": "^22.1.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "husky": "^9.1.7",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vite-plugin-logseq": "^1.1.2",
    "vite-tsconfig-paths": "^5.0.0"
  }
}
