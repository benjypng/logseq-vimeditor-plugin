{
  "name": "logseq-richtexteditor-plugin",
  "author": "benjypng",
  "description": "Adds a rich-text editor to your graph.",
  "license": "MIT",
  "logseq": {
    "id": "logseq-richtexteditor-plugin",
    "title": "logseq-richtexteditor-plugin",
    "icon": "./icon.svg",
    "main": "dist/index.html"
  },
  "scripts": {
    "dev": "bunx vite",
    "build": "bunx vite build",
    "prepare": "husky",
    "lint:precommit": "echo \"Running biome\" && bunx biome check . --write && echo \"Running tsc\" && tsc --noEmit"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/github",
        {
          "assets": [
            "logseq-richtexteditor-plugin.zip"
          ]
        }
      ]
    ]
  },
  "dependencies": {
    "@logseq/libs": "^0.0.17",
    "@tiptap/core": "^2.5.9",
    "@tiptap/extension-highlight": "^2.6.4",
    "@tiptap/extension-table": "^2.5.9",
    "@tiptap/extension-table-cell": "^2.5.9",
    "@tiptap/extension-table-header": "^2.5.9",
    "@tiptap/extension-table-row": "^2.5.9",
    "@tiptap/extension-text-align": "^2.5.9",
    "@tiptap/extension-underline": "^2.5.9",
    "@tiptap/react": "^2.5.9",
    "@tiptap/starter-kit": "^2.5.9",
    "lucide-react": "^0.427.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/node": "^22.1.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "husky": "^9.1.7",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vite-plugin-logseq": "^1.1.2",
    "vite-tsconfig-paths": "^5.0.0"
  }
}
